{
  "name": "oh-my-ai",
  "version": "1.0.3",
  "main": "index.ts",
  "bin": {
    "oh-my-ai": "bin/oh-my-ai.ts"
  },
  "scripts": {
    "start": "bun run index.ts",
    "build": "bun build index.ts --outdir .bun-build --target=bun",
    "test": "bun run tests/run-tests.js",
    "test:gemini": "bun run tests/test-gemini.js",
    "test:openai": "bun run tests/test-openai.js",
    "dev": "bun --watch run index.ts",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release:changeset": "changeset publish",
    "release:npm": "bun run release:changeset",
    "release": "./scripts/release.sh"
  },
  "keywords": [
    "bun",
    "llm",
    "api-proxy",
    "key-rotation",
    "openai",
    "gemini",
    "groq",
    "openrouter"
  ],
  "author": "Hiro <laciferin@gmail.com>",
  "license": "GPL-3.0-or-later",
  "description": "Bun-native LLM proxy runner with automatic key rotation and a live admin panel.",
  "engines": {
    "bun": ">=1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ideo-mind/oh-my-ai.git"
  },
  "bugs": {
    "url": "https://github.com/ideo-mind/oh-my-ai/issues"
  },
  "homepage": "https://github.com/ideo-mind/oh-my-ai#readme",
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@types/bun": "^1.3.11"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0"
  }
}
